# AstonomiQ P2P — backend environment. Copy to .env; never commit .env.

# Neon PostgreSQL — database intelezen_ap_discounting
DATABASE_URL=postgresql+asyncpg://user:password@host/intelezen_ap_discounting?ssl=require

# OpenAI (AI agents: invoice OCR, pool recommender, match analyst)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# App
APP_ENV=development
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:5175

# Integrations default mode (per-integration override in the integrations table)
INTEGRATION_MODE_DEFAULT=simulated

# Intelezen-provided API keys — set when flipping integrations to live
# INTELEZEN_GST_API_KEY=
# INTELEZEN_PAN_API_KEY=
# INTELEZEN_UDYAM_API_KEY=
# INTELEZEN_PENNYDROP_API_KEY=
# INTELEZEN_ESIGN_API_KEY=
# INTELEZEN_BANK_API_KEY=
# INTELEZEN_ERP_API_KEY=
# INTELEZEN_IRP_API_KEY=
# INTELEZEN_GSTN_API_KEY=
# INTELEZEN_TREDS_API_KEY=
